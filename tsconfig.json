      ],
      "@cb/ds-components/checkbox": [
        "./projects/ds-components/checkbox/src/public-api.ts",
        "./dist/ds-components/checkbox"
      ],
      "@cb/ds-components/input": [
        "./projects/ds-components/input/src/public-api.ts",
        "./dist/ds-components/input"
      ],
      "@cb/ds-components/tabs": [
