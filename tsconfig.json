      "@cb/ds-components/breadcrumbs": [
        "./projects/ds-components/breadcrumbs/src/public-api.ts",
        "./dist/ds-components/breadcrumbs"
      ],
      "@cb/ds-components/divider": [
        "./projects/ds-components/divider/src/public-api.ts",
